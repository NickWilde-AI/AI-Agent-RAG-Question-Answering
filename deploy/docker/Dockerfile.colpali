# ColPali rerank 独立服务（需 NVIDIA GPU + 宿主机已安装 nvidia-container-toolkit）。
# 权重目录挂载只读：./models/colpali-v1.3 -> /models/colpali-v1.3
#
# 构建：docker build -f deploy/docker/Dockerfile.colpali -t rag-colpali:latest .

FROM pytorch/pytorch:2.2.2-cuda12.1-cudnn8-runtime

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    COLPALI_MODEL_DIR=/models/colpali-v1.3

COPY requirements/colpali-docker.txt /tmp/requirements-colpali-docker.txt
RUN pip install --upgrade pip && pip install -r /tmp/requirements-colpali-docker.txt

COPY scripts/__init__.py ./scripts/__init__.py
COPY scripts/colpali_rerank_service.py ./scripts/colpali_rerank_service.py

EXPOSE 9001

HEALTHCHECK --interval=45s --timeout=10s --start-period=120s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:9001/health', timeout=5)"

CMD ["uvicorn", "scripts.colpali_rerank_service:app", "--host", "0.0.0.0", "--port", "9001"]
