# 复制本文件为 .env 后填入真实值（勿将 .env 提交到 Git）
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OAPI_API_KEY=

RAG_ENABLE_REAL_EMBEDDING=false
RAG_ENABLE_LLM_ROUTER=false
RAG_ENABLE_LLM_VERIFIER=false
RAG_ENABLE_PLAN_EXECUTE_LOOP=false
RAG_ENABLE_LANGGRAPH=false
RAG_ENABLE_BM25_FALLBACK=true
RAG_BM25_K1=1.2
RAG_BM25_B=0.75
RAG_LLM_MAX_RETRIES=2
RAG_LLM_RETRY_BASE_SECONDS=0.6
RAG_LLM_RETRY_MAX_SECONDS=4.0
SENTRY_DSN=
RAG_ENABLE_RATE_LIMIT=true
RAG_RATE_LIMIT_RPS=5
RAG_RATE_LIMIT_BURST=10
RAG_ENABLE_ROUTER_CIRCUIT_BREAKER=true
RAG_ROUTER_CB_FAILURES=5
RAG_ROUTER_CB_RECOVERY_SECONDS=30
RAG_ENABLE_VLM_CIRCUIT_BREAKER=true
RAG_VLM_CB_FAILURES=3
RAG_VLM_CB_RECOVERY_SECONDS=30

RAG_TOPK_DEFAULT=3
RAG_TOPK_RETRY_MULTIPLIER=2
RAG_TOPK_FACT=3
RAG_TOPK_MULTI_PAGE=5
RAG_TOPK_CHART=4
RAG_MAX_RETRY_TOPK=12
RAG_ENABLE_BRANCH_FALLBACK=true
RAG_VECTOR_DIM=256
RAG_ENABLE_QUERY_REWRITE=true
RAG_ENABLE_QUERY_EXPANSION=true
RAG_MAX_QUERY_VARIANTS=4
RAG_RRF_K=60
RAG_RETRIEVAL_DIVERSITY_PER_DOC=3
RAG_ENABLE_AGENTIC_RETRY_REFINE=true
RAG_AGENTIC_RETRY_MAX_MISSING_TERMS=6

RAG_VECTOR_BACKEND=inmemory
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=rag_pages

# 本地进程：memory；docker compose -f docker-compose.cloud-gpu.yml：redis（内网 redis://redis:6379/0）
RAG_SESSION_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
RAG_REDIS_TTL_SECONDS=1800
RAG_ENABLE_SESSION_CACHE=true
RAG_SESSION_CACHE_REQUIRE_VERIFIED=true
RAG_SESSION_MAX_HISTORY=50

# 研究任务：单工具/总任务超时、进程内 worker 与有界等待队列
RAG_RESEARCH_TOOL_TIMEOUT_SECONDS=30
RAG_RESEARCH_JOB_TIMEOUT_SECONDS=300
RAG_RESEARCH_DISPATCH_WORKERS=2
RAG_RESEARCH_DISPATCH_QUEUE=32
RAG_RESEARCH_ENGINE_CACHE_SIZE=16

# 逗号分隔；生产请填写真实前端域名，不要使用 * + credentials
RAG_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# 上传安全边界
RAG_UPLOAD_MAX_BYTES=20971520
RAG_UPLOAD_MAX_PAGES=500
RAG_UPLOAD_MAX_UNCOMPRESSED_BYTES=209715200

# 轻量建库默认不渲染 PDF 页图；启用 ColPali/VLM 建库时设为 1
RAG_BUILD_PAGE_IMAGES=0
RAG_BUILD_DPI=144

RAG_ENABLE_MULTIMODAL_EMBEDDING=false
RAG_ENABLE_COLPALI_RERANK=false
RAG_ENABLE_FUNCTION_CALLING_ROUTER=true
RAG_MULTIMODAL_EMBEDDING_API=
RAG_COLPALI_RERANK_API=

RAG_VLM_API=
RAG_CHART_PARSING_API=

COLPALI_MODEL_ID=vidore/colpali-v1.3
COLPALI_MODEL_DIR=models/colpali-v1.3
